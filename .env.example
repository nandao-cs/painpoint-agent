# Copy to .env (gitignored) and fill in.

# Reddit data API (create an app: https://www.reddit.com/prefs/apps -> "script")
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=painpoint-agent/0.1 by u/yourname

# StackExchange (optional — raises the anonymous rate limit). Register at
# https://stackapps.com/apps/oauth/register
STACKEXCHANGE_KEY=

# Hacker News (Algolia) needs no key.
